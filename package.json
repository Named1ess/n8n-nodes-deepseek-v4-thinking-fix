{
  "name": "n8n-nodes-deepseek-v4",
  "version": "0.7.15",
  "description": "n8n community node for DeepSeek chat models (Pro / Flash) with reasoning_content (Chain-of-Thought) support, usable as a LangChain sub-node inside the AI Agent and Basic LLM Chain.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "deepseek",
    "langchain",
    "llm",
    "ai",
    "reasoning",
    "chain-of-thought"
  ],
  "license": "MIT",
  "homepage": "https://github.com/your-org/n8n-nodes-deepseek",
  "author": {
    "name": "Your Name",
    "email": "you@example.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/n8n-nodes-deepseek.git"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DeepSeekApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DeepSeekReasoner/DeepSeekReasoner.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@langchain/core": "^0.3.80",
    "@langchain/openai": "^0.3.17",
    "n8n-workflow": "*"
  }
}
